# Clerk (Configure > API Keys in your Clerk dashboard)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# PostHog (Project Settings > Project API Key)
EXPO_PUBLIC_POSTHOG_PROJECT_TOKEN=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Convex — run `npx convex dev` once to log in, create/link a project, and have it write this for you.
EXPO_PUBLIC_CONVEX_URL=

# RevenueCat (Project Settings > API Keys). Leave blank to ship without a paywall —
# Pro-gated screens fall back to a "not configured" message instead of crashing.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
